// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Vertical {
  ELECTRONICS
  GROCERY
  FNL
}

enum StoreStatus {
  ACTIVE
  INACTIVE
  TEMPORARILY_CLOSED
}

/// Employee role enum.
///
/// Phase 5.1 (F&L pilot — Reliance Trends): added `OMNI` and `PT` to mirror
/// what we found in the Mar'26 Week-1 working file (297 Omni + 124 PT rows
/// across 30K employees in 2,138 stores). RIL's `Incentive Policy v1` only
/// names SM/DM/CSA — so until format team confirms eligibility for these
/// roles on the Tue 28 Apr call, the engine routes both `OMNI` and `PT`
/// through the CSA pool (see `roleForPool()` in
/// `src/server/calculations/engines.ts`). Adding them to the enum now
/// avoids a migration once the answer lands.
///
/// Phase 6.1 (Grocery HR Sales pilot): added `ASM` (Assistant Store Manager)
/// because RIL's Grocery slab matrix breaks managers into SM / ASM / Other
/// Mgrl (DM-equivalent) for the Stores tier. The .xlsb working file has
/// "Asst Store Manager" as a distinct Position Name. ASM and SM share the
/// same slab amounts in the v1 matrix but the policy keeps them separate,
/// so we mirror that — if the policy diverges later, no migration needed.
///
/// CSA (the Reliance term) maps to our `SA` value — this codebase pre-dates
/// the F&L scope and uses `SA` as the customer-facing-staff label. Ingest
/// helpers normalise either string to `SA`.
enum EmployeeRole {
  SM
  DM
  ASM
  SA
  BA
  OMNI
  PT
}

/// Phase 6.1 — Grocery format-tier discriminator. The HR Sales slab matrix
/// has two completely different tables — one for FreshPik (a "Large
/// Format" store with bigger payouts and finer achievement bands) and one
/// for the Smart family (Smart, Smart Bazaar, Smart Point, gofresh). The
/// engine resolves the tier per-store via a constant map keyed on
/// `StoreMaster.storeFormat` (see `formatTierFor()` in `engines.ts`).
enum FormatTier {
  LARGE_FORMAT
  STORES
}

/// Phase 6.1 — Grocery slab role buckets. The Stores tier uses 5 distinct
/// rows (SM / ASM / OTHER_MGRL / CSA / PT); the Large tier collapses to 3
/// (SM_ASM combined / OTHER_MGRL / ASSOCIATES combined). Engine maps an
/// `(EmployeeRole, FormatTier)` pair to one of these buckets — see
/// `roleBucketFor()` in `engines.ts`.
enum GroceryRoleBucket {
  SM           // Stores tier
  ASM          // Stores tier
  OTHER_MGRL   // Both tiers (Department Manager-equivalent)
  CSA          // Stores tier
  PT           // Stores tier
  SM_ASM       // Large tier (SM + ASM combined)
  ASSOCIATES   // Large tier (CSA + PT combined)
}

/// Phase 6.1 — Store-level monthly quality ratings. RIL's Grocery feed
/// carries Mystery Shopper and POP Compliance ratings as Green/Amber/Red
/// per store per month. Both ratings drive the `StoreSalesStatus` (see
/// below) which gates manager payouts.
enum StoreRating {
  GREEN
  AMBER
  RED
}

/// Phase 6.1 — Quality-gate outcome for a Grocery store-month. Computed
/// from the two ratings at ingest time but stored as the canonical truth
/// value so ops can manually override (e.g., "Amber but approved by RM").
///   - ALL_STAFF_QUALIFIED:        SM/ASM/DM/CSA/PT all earn (when sales gate also passes)
///   - ONLY_ASSOCIATES_QUALIFIED:  Managers blocked, only CSA/PT earn
///   - NONE_QUALIFIED:             Nobody earns (both ratings RED, or explicit ops override)
enum StoreSalesStatus {
  ALL_STAFF_QUALIFIED
  ONLY_ASSOCIATES_QUALIFIED
  NONE_QUALIFIED
}

/// Phase 6.1 — Funding source for an incentive plan. Drives ledger
/// labelling, approval flow, and downstream reporting (RIL P&L vs vendor
/// recharge). Default RIL preserves backward-compat — existing plans don't
/// need to be touched.
enum FundingSource {
  RIL
  VENDOR
}

enum PayrollStatus {
  ACTIVE
  NOTICE_PERIOD
  DISCIPLINARY_ACTION
  LONG_LEAVE_UNAUTHORISED
  INACTIVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LEAVE_APPROVED
  LEAVE_UNAPPROVED
  HOLIDAY
  WEEK_OFF
}

enum TransactionType {
  NORMAL
  SFS
  PAS
  JIOMART
}

enum Channel {
  OFFLINE
  ONLINE
}

enum PeriodType {
  MONTHLY
  WEEKLY
  CAMPAIGN
}

enum ApprovalStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ACTIVE
}

enum FormulaType {
  PER_UNIT
  CAMPAIGN_SLAB
  WEEKLY_POOL
}

enum CampaignDistributionRule {
  EQUAL
}

enum CalculationStatus {
  IN_PROGRESS
  FINAL
}

enum CalcRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SUPERSEDED
}

enum CalcRunTrigger {
  INGESTION
  MANUAL_RECOMPUTE
  SCHEDULED_CRON
  PLAN_PUBLISH
  ATTENDANCE_UPDATE
  BACKFILL
}

enum AuditEntityType {
  PLAN
  TARGET
  CAMPAIGN
  CALCULATION
}

enum AuditAction {
  CREATED
  SUBMITTED
  APPROVED
  REJECTED
  CALCULATED
}

/// Entity types a human decision chain can attach to. PAYOUT is reserved for
/// the payout-disbursement workflow that lands in a later phase — today it is
/// unused but writing it into the enum now avoids a future migration.
enum ApprovalEntityType {
  PLAN
  TARGET
  PAYOUT
}

enum ApprovalDecision {
  PENDING
  APPROVED
  REJECTED
  SUPERSEDED
}

/// Lifecycle of an `IngestionBatch`. Firehose POSTs from Reliance land as
/// RECEIVED → rows written to sales_transaction → PROCESSING while the
/// recompute job runs → COMPLETED (all good), PARTIAL (some rows rejected
/// but the batch is closed), or FAILED (insert or recompute blew up).
enum IngestionStatus {
  RECEIVED
  PROCESSING
  COMPLETED
  PARTIAL
  FAILED
}

/// Queue state for a deferred recompute. `POST /api/ingest/sales` enqueues
/// one of these per batch instead of running the engine in-request. The cron
/// worker (`/api/cron/run-jobs`) claims PENDING jobs with `SELECT ... FOR
/// UPDATE SKIP LOCKED` semantics so multiple workers don't double-claim.
enum RecomputeJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model StoreMaster {
  storeCode          String      @id @map("store_code") @db.VarChar(32)
  storeName          String      @map("store_name")
  vertical           Vertical
  storeFormat        String      @map("store_format")
  state              String
  city               String
  storeStatus        StoreStatus @default(ACTIVE) @map("store_status")
  operationalSince   DateTime    @map("operational_since") @db.Date
  employees          EmployeeMaster[]
  attendance         Attendance[]
  salesTransactions  SalesTransaction[]
  targets            Target[]
  campaignTargets    CampaignStoreTarget[]
  incentiveLedger    IncentiveLedger[]

  @@map("store_master")
}

model EmployeeMaster {
  employeeId         String             @id @map("employee_id") @db.VarChar(64)
  employeeName       String             @map("employee_name")
  role               EmployeeRole
  storeCode          String             @map("store_code") @db.VarChar(32)
  department         String?
  payrollStatus      PayrollStatus      @default(ACTIVE) @map("payroll_status")
  dateOfJoining      DateTime           @map("date_of_joining") @db.Date
  dateOfExit         DateTime?          @map("date_of_exit") @db.Date
  /// Denormalized flag for fast auth/middleware checks. Mirrors whether
  /// an `EmployeeAdminAccess` row exists — kept in sync by the access
  /// grant/revoke helpers. `true` means this employee can log into the
  /// admin web app; granular capabilities live in `adminAccess`.
  hasAdminAccess     Boolean            @default(false) @map("has_admin_access")
  store              StoreMaster        @relation(fields: [storeCode], references: [storeCode], onDelete: Restrict)
  attendance         Attendance[]
  sales              SalesTransaction[]
  incentiveLedger    IncentiveLedger[]
  credential         UserCredential?
  adminAccess        EmployeeAdminAccess?
  submittedApprovals ApprovalRequest[]  @relation("ApprovalSubmitter")
  decidedApprovals   ApprovalRequest[]  @relation("ApprovalDecider")
  monthlyInputs      EmployeeMonthlyInput[]

  @@index([storeCode])
  @@index([hasAdminAccess])
  @@map("employee_master")
}

/// Granular admin capabilities for an employee flagged `hasAdminAccess = true`.
/// One row per admin; zero rows means the employee cannot log into the admin
/// web app even if their credential exists. `verticals` is an allow-list —
/// empty array means "all verticals" (super-admin).
///
/// Permission flags are checked by `requirePermission(user, flag, {vertical})`
/// in `src/lib/permissions.ts`. The scope rules:
///   - canViewAll:        read any vertical's dashboard/leaderboard
///   - canEditIncentives: create/edit plans, campaigns, slabs, multipliers
///   - canSubmitApproval: flip a plan or target batch to SUBMITTED
///   - canApprove:        approve/reject a submitted ApprovalRequest
///   - canManageUsers:    grant/revoke admin access for other employees
///   - canUploadData:     attendance upload, sales CSV import
model EmployeeAdminAccess {
  id                Int            @id @default(autoincrement())
  employeeId        String         @unique @map("employee_id") @db.VarChar(64)
  verticals         Vertical[]
  canViewAll        Boolean        @default(false) @map("can_view_all")
  canEditIncentives Boolean        @default(false) @map("can_edit_incentives")
  canSubmitApproval Boolean        @default(false) @map("can_submit_approval")
  canApprove        Boolean        @default(false) @map("can_approve")
  canManageUsers    Boolean        @default(false) @map("can_manage_users")
  canUploadData     Boolean        @default(false) @map("can_upload_data")
  grantedBy         String?        @map("granted_by")
  grantedAt         DateTime       @default(now()) @map("granted_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  employee          EmployeeMaster @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@map("employee_admin_access")
}

/// One row per decision chain on a Plan / Target batch / Payout. Captures the
/// before-after-chain-after story: who submitted, which approvers have seen
/// it, who decided, and if re-submitted, which prior request was superseded.
///
/// The `changeSnapshot` JSON is the plan/target diff at submission time.
/// Reads hydrate the UI: pending queue, history tab, and audit trail.
model ApprovalRequest {
  id              Int                  @id @default(autoincrement())
  entityType      ApprovalEntityType   @map("entity_type")
  /// For PLAN: incentive_plan.id. For TARGET: the lowest target.id in the
  /// submitted batch (used as a stable reference for drill-in).
  entityId        Int                  @map("entity_id")
  /// Groups multiple rows into one logical submission. For TARGET, this is
  /// typically "<vertical>-<periodType>" so a CSV import creates one
  /// ApprovalRequest even though it writes N target rows.
  batchKey        String?              @map("batch_key")
  vertical        Vertical?
  title           String
  summary         String?
  changeSnapshot  Json?                @map("change_snapshot")
  submissionNote  String?              @map("submission_note")
  submittedBy     String               @map("submitted_by") @db.VarChar(64)
  submittedAt     DateTime             @default(now()) @map("submitted_at")
  /// JSON array of { employeeId, at } entries — approvers who have loaded
  /// the detail view. Used by the UI to surface "seen by X".
  seenBy          Json                 @default("[]") @map("seen_by")
  decision        ApprovalDecision     @default(PENDING)
  decidedBy       String?              @map("decided_by") @db.VarChar(64)
  decidedAt       DateTime?            @map("decided_at")
  decisionNote    String?              @map("decision_note")
  supersededById  Int?                 @map("superseded_by_id")
  createdAt       DateTime             @default(now()) @map("created_at")
  updatedAt       DateTime             @updatedAt @map("updated_at")

  submitter       EmployeeMaster       @relation("ApprovalSubmitter", fields: [submittedBy], references: [employeeId], onDelete: Restrict)
  decider         EmployeeMaster?      @relation("ApprovalDecider", fields: [decidedBy], references: [employeeId], onDelete: Restrict)
  supersededBy    ApprovalRequest?     @relation("ApprovalSupersedes", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes      ApprovalRequest[]    @relation("ApprovalSupersedes")

  @@index([decision, submittedAt])
  @@index([entityType, entityId])
  @@index([vertical, decision])
  @@index([batchKey])
  @@map("approval_request")
}

model UserCredential {
  id             Int            @id @default(autoincrement())
  employerId     String         @unique @map("employer_id") @db.VarChar(64)
  employeeId     String         @unique @map("employee_id") @db.VarChar(64)
  password       String         @map("password")
  isActive       Boolean        @default(true) @map("is_active")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  lastLoginAt    DateTime?      @map("last_login_at")
  employee       EmployeeMaster @relation(fields: [employeeId], references: [employeeId], onDelete: Cascade)

  @@index([employerId, isActive])
  @@map("user_credential")
}

model Attendance {
  id         Int              @id @default(autoincrement())
  employeeId String           @map("employee_id") @db.VarChar(64)
  storeCode  String           @map("store_code") @db.VarChar(32)
  date       DateTime         @db.Date
  status     AttendanceStatus
  source     String?          @default("upload")
  uploadId   Int?             @map("upload_id")
  employee   EmployeeMaster   @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)
  store      StoreMaster      @relation(fields: [storeCode], references: [storeCode], onDelete: Restrict)
  upload     AttendanceUpload? @relation(fields: [uploadId], references: [id], onDelete: SetNull)

  @@unique([employeeId, date])
  @@index([storeCode, date])
  @@map("attendance")
}

/// Batch record for an attendance upload. One row per uploaded file/API push.
/// Lets us audit "where did this attendance data come from" and recompute
/// F&L incentives for the periods the batch touches.
model AttendanceUpload {
  id             Int          @id @default(autoincrement())
  uploadedBy     String       @map("uploaded_by")
  fileName       String?      @map("file_name")
  rowCount       Int          @default(0) @map("row_count")
  periodStart    DateTime?    @map("period_start") @db.Date
  periodEnd      DateTime?    @map("period_end") @db.Date
  storeCodes     String[]     @map("store_codes")
  uploadedAt     DateTime     @default(now()) @map("uploaded_at")
  attendanceRows Attendance[]

  @@index([uploadedAt])
  @@map("attendance_upload")
}

model SalesTransaction {
  transactionId      String           @id @map("transaction_id") @db.VarChar(96)
  transactionDate    DateTime         @map("transaction_date") @db.Date
  storeCode          String           @map("store_code") @db.VarChar(32)
  vertical           Vertical
  storeFormat        String           @map("store_format")
  employeeId         String?          @map("employee_id") @db.VarChar(64)
  department         String?
  articleCode        String           @map("article_code")
  productFamilyCode  String?          @map("product_family_code")
  brand              String?
  quantity           Int
  grossAmount        Decimal          @map("gross_amount") @db.Decimal(14, 2)
  taxAmount          Decimal          @map("tax_amount") @db.Decimal(14, 2)
  totalAmount        Decimal          @map("total_amount") @db.Decimal(14, 2)
  transactionType    TransactionType  @map("transaction_type")
  channel            Channel
  store              StoreMaster      @relation(fields: [storeCode], references: [storeCode], onDelete: Restrict)
  employee           EmployeeMaster?  @relation(fields: [employeeId], references: [employeeId], onDelete: SetNull)

  @@index([storeCode, transactionDate])
  @@index([vertical, transactionDate])
  @@index([transactionType, channel])
  @@index([employeeId, transactionDate])
  @@map("sales_transaction")
}

model Target {
  id                Int            @id @default(autoincrement())
  storeCode         String         @map("store_code") @db.VarChar(32)
  vertical          Vertical
  department        String?
  productFamilyCode String?        @map("product_family_code")
  productFamilyName String?        @map("product_family_name")
  targetValue       Decimal        @map("target_value") @db.Decimal(14, 2)
  periodType        PeriodType     @map("period_type")
  periodStart       DateTime       @map("period_start") @db.Date
  periodEnd         DateTime       @map("period_end") @db.Date
  status            ApprovalStatus @default(DRAFT)
  submittedBy       String?        @map("submitted_by")
  approvedBy        String?        @map("approved_by")
  batchKey          String?        @map("batch_key") @db.VarChar(64)
  createdAt         DateTime       @default(now()) @map("created_at")
  store             StoreMaster    @relation(fields: [storeCode], references: [storeCode], onDelete: Restrict)

  @@index([storeCode, vertical, periodStart, periodEnd])
  @@index([status, periodType])
  @@index([batchKey])
  @@map("target")
}

/// Top-level incentive plan. `config` is a JSON discriminator carrying
/// plan-shape-specific knobs:
///   - F&L weekly:        `{ poolPct, minWorkingDays }`
///   - Grocery campaign:  uses CampaignConfig + CampaignPayoutSlab
///   - **Grocery HR Sales (Phase 6.1)**: `{ mode: "HR_SALES" }`
///       Resolves to `computeGroceryHrSales()` which reads slabs from
///       `GrocerySalesSlab`, store-month metrics from `StoreMonthlyMetric`,
///       and per-employee monthly inputs from `EmployeeMonthlyInput`.
///   - **Grocery Category PIP (Phase 6.1)**: `{ mode: "CATEGORY_PIP" }`
///       Resolves to `computeGroceryCategoryPip()` which reads article
///       rates from `CategoryPipArticle` and matches against
///       `SalesTransaction.articleCode`.
///
/// `fundingSource` (RIL / VENDOR) is structured rather than buried in
/// config because it affects approval flow and ledger labelling — the
/// admin queue filters by it and downstream reports group by it.
model IncentivePlan {
  id                    Int                    @id @default(autoincrement())
  planName              String                 @map("plan_name")
  vertical              Vertical
  formulaType           FormulaType            @map("formula_type")
  periodType            PeriodType             @map("period_type")
  status                ApprovalStatus         @default(DRAFT)
  version               Int                    @default(1)
  /// Phase 6.1 — RIL P&L vs vendor-funded (e.g., Dairy Day for Ice Cream
  /// PIP). Default RIL keeps existing plans unchanged.
  fundingSource         FundingSource          @default(RIL) @map("funding_source")
  effectiveFrom         DateTime?              @map("effective_from") @db.Date
  effectiveTo           DateTime?              @map("effective_to") @db.Date
  createdBy             String?                @map("created_by")
  submittedBy           String?                @map("submitted_by")
  approvedBy            String?                @map("approved_by")
  rejectionReason       String?                @map("rejection_reason")
  config                Json?
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  productIncentiveSlabs ProductIncentiveSlab[]
  achievementMultipliers AchievementMultiplier[]
  campaignConfigs       CampaignConfig[]
  fnlRoleSplits         FnlRoleSplit[]
  grocerySalesSlabs     GrocerySalesSlab[]
  categoryPipArticles   CategoryPipArticle[]
  applicability         PlanApplicability[]
  incentiveLedger       IncentiveLedger[]
  calculationRuns       CalculationRun[]
  employeePeriodRollups EmployeePeriodRollup[]
  storePeriodRollups    StorePeriodRollup[]

  @@index([vertical, status, effectiveFrom, effectiveTo])
  @@index([fundingSource, status])
  @@map("incentive_plan")
}

/// Scoping rules for a plan: which vertical/role/department combinations it applies to.
/// A plan with zero applicability rows applies to its vertical only (legacy fallback).
/// A plan with multiple rows applies to the UNION of those rules.
/// Employees can earn from multiple concurrent plans; each matching plan produces its
/// own ledger + rollup rows.
model PlanApplicability {
  id           Int           @id @default(autoincrement())
  planId       Int           @map("plan_id")
  vertical     Vertical
  role         EmployeeRole?
  department   String?
  priority     Int           @default(0)
  plan         IncentivePlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([vertical, role, department])
  @@index([planId])
  @@map("plan_applicability")
}

model ProductIncentiveSlab {
  id               Int          @id @default(autoincrement())
  planId           Int          @map("plan_id")
  productFamily    String       @map("product_family")
  brandFilter      String       @map("brand_filter")
  priceFrom        Decimal      @map("price_from") @db.Decimal(14, 2)
  priceTo          Decimal      @map("price_to") @db.Decimal(14, 2)
  incentivePerUnit Decimal      @map("incentive_per_unit") @db.Decimal(14, 2)
  effectiveFrom    DateTime?    @map("effective_from") @db.Date
  effectiveTo      DateTime?    @map("effective_to") @db.Date
  plan             IncentivePlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId, productFamily])
  @@map("product_incentive_slab")
}

model AchievementMultiplier {
  id              Int           @id @default(autoincrement())
  planId          Int           @map("plan_id")
  achievementFrom Decimal       @map("achievement_from") @db.Decimal(8, 2)
  achievementTo   Decimal       @map("achievement_to") @db.Decimal(8, 2)
  multiplierPct   Decimal       @map("multiplier_pct") @db.Decimal(8, 2)
  effectiveFrom   DateTime?     @map("effective_from") @db.Date
  effectiveTo     DateTime?     @map("effective_to") @db.Date
  plan            IncentivePlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId, achievementFrom, achievementTo])
  @@map("achievement_multiplier")
}

model CampaignConfig {
  id               Int                      @id @default(autoincrement())
  planId           Int                      @map("plan_id")
  campaignName     String                   @map("campaign_name")
  startDate        DateTime                 @map("start_date") @db.Date
  endDate          DateTime                 @map("end_date") @db.Date
  channel          Channel                  @default(OFFLINE)
  distributionRule CampaignDistributionRule @default(EQUAL) @map("distribution_rule")
  status           ApprovalStatus           @default(DRAFT)
  plan             IncentivePlan            @relation(fields: [planId], references: [id], onDelete: Restrict)
  articles         CampaignArticle[]
  storeTargets     CampaignStoreTarget[]
  payoutSlabs      CampaignPayoutSlab[]
  incentiveLedger  IncentiveLedger[]

  @@index([planId, status, startDate, endDate])
  @@map("campaign_config")
}

model CampaignArticle {
  id          Int            @id @default(autoincrement())
  campaignId  Int            @map("campaign_id")
  articleCode String         @map("article_code")
  brand       String
  description String
  campaign    CampaignConfig @relation(fields: [campaignId], references: [id], onDelete: Restrict)

  @@unique([campaignId, articleCode])
  @@map("campaign_article")
}

model CampaignStoreTarget {
  id          Int            @id @default(autoincrement())
  campaignId  Int            @map("campaign_id")
  storeCode   String         @map("store_code") @db.VarChar(32)
  targetValue Decimal        @map("target_value") @db.Decimal(14, 2)
  campaign    CampaignConfig @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  store       StoreMaster    @relation(fields: [storeCode], references: [storeCode], onDelete: Restrict)

  @@unique([campaignId, storeCode])
  @@map("campaign_store_target")
}

model CampaignPayoutSlab {
  id              Int            @id @default(autoincrement())
  campaignId      Int            @map("campaign_id")
  achievementFrom Decimal        @map("achievement_from") @db.Decimal(8, 2)
  achievementTo   Decimal        @map("achievement_to") @db.Decimal(8, 2)
  perPieceRate    Decimal        @map("per_piece_rate") @db.Decimal(10, 2)
  campaign        CampaignConfig @relation(fields: [campaignId], references: [id], onDelete: Restrict)

  @@index([campaignId, achievementFrom, achievementTo])
  @@map("campaign_payout_slab")
}

model FnlRoleSplit {
  id               Int           @id @default(autoincrement())
  planId           Int           @map("plan_id")
  numSms           Int           @map("num_sms")
  numDms           Int           @map("num_dms")
  saPoolPct        Decimal       @map("sa_pool_pct") @db.Decimal(8, 2)
  smSharePct       Decimal       @map("sm_share_pct") @db.Decimal(8, 2)
  dmSharePerDmPct  Decimal       @default(0) @map("dm_share_per_dm_pct") @db.Decimal(8, 2)
  plan             IncentivePlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@unique([planId, numSms, numDms])
  @@map("fnl_role_split")
}

model IncentiveLedger {
  id                 Int               @id @default(autoincrement())
  planId             Int               @map("plan_id")
  campaignId         Int?              @map("campaign_id")
  calculationRunId   String?           @map("calculation_run_id") @db.Uuid
  employeeId         String            @map("employee_id") @db.VarChar(64)
  storeCode          String            @map("store_code") @db.VarChar(32)
  vertical           Vertical
  periodStart        DateTime          @map("period_start") @db.Date
  periodEnd          DateTime          @map("period_end") @db.Date
  baseIncentive      Decimal           @default(0) @map("base_incentive") @db.Decimal(14, 2)
  multiplierApplied  Decimal?          @map("multiplier_applied") @db.Decimal(8, 2)
  achievementPct     Decimal?          @map("achievement_pct") @db.Decimal(8, 2)
  finalIncentive     Decimal           @default(0) @map("final_incentive") @db.Decimal(14, 2)
  calculationDetails Json?             @map("calculation_details")
  calculationStatus  CalculationStatus @default(IN_PROGRESS) @map("calculation_status")
  calculatedAt       DateTime          @default(now()) @map("calculated_at")
  plan               IncentivePlan     @relation(fields: [planId], references: [id], onDelete: Restrict)
  campaign           CampaignConfig?   @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  calculationRun     CalculationRun?   @relation(fields: [calculationRunId], references: [id], onDelete: SetNull)
  employee           EmployeeMaster    @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)
  store              StoreMaster       @relation(fields: [storeCode], references: [storeCode], onDelete: Restrict)

  @@index([storeCode, vertical, periodStart, periodEnd])
  @@index([employeeId, periodStart, periodEnd])
  @@index([planId, campaignId])
  @@index([calculationRunId])
  @@map("incentive_ledger")
}

/// A single calculation pass for a (plan, period) scope. The engine writes new
/// ledger + rollup rows tagged with this run's id. On success, the prior run
/// for the same scope is flipped to SUPERSEDED in the same transaction. Reads
/// filter to runs where `isCurrent = true AND status = SUCCEEDED`.
///
/// History is preserved — superseded runs stay queryable for audit and
/// time-travel. The "current" ledger is defined by the latest successful run.
model CalculationRun {
  id                String               @id @default(uuid()) @db.Uuid
  planId            Int                  @map("plan_id")
  planVersion       Int                  @map("plan_version")
  vertical          Vertical
  periodStart       DateTime             @map("period_start") @db.Date
  periodEnd         DateTime             @map("period_end") @db.Date
  scopeStoreCodes   String[]             @map("scope_store_codes")
  status            CalcRunStatus        @default(PENDING)
  isCurrent         Boolean              @default(false) @map("is_current")
  trigger           CalcRunTrigger
  triggeredByUserId String?              @map("triggered_by_user_id")
  inputsHash        String?              @map("inputs_hash")
  ledgerRowCount    Int                  @default(0) @map("ledger_row_count")
  startedAt         DateTime             @default(now()) @map("started_at")
  completedAt       DateTime?            @map("completed_at")
  errorMessage      String?              @map("error_message") @db.Text
  plan              IncentivePlan        @relation(fields: [planId], references: [id], onDelete: Restrict)
  ledgerEntries     IncentiveLedger[]
  employeeRollups   EmployeePeriodRollup[]
  storeRollups      StorePeriodRollup[]
  dailyRollups      StoreDailyRollup[]

  @@index([planId, periodStart, periodEnd, status])
  @@index([planId, periodStart, isCurrent])
  @@index([status, startedAt])
  /// Hot path: every ledger/rollup read filters on
  /// `isCurrent=true AND status='SUCCEEDED'` (see currentLedgerWhere).
  /// Without this, the dashboard joins sequential-scan calculation_run.
  @@index([isCurrent, status])
  @@map("calculation_run")
}

/// Per-day × store × vertical sales rollup. Maintained by the calculation engine
/// inside each successful run. Primary use: dashboard daily trendlines and
/// ingestion reconciliation vs raw totals. Not a replacement for raw
/// transaction drilldown — use `sales_transaction` for txn-level UI.
/// Phase 5.1 (F&L pilot — Reliance Trends Incentive Policy v1) —
/// per-store × period external metrics that aren't derivable from sales
/// transactions. Two feeds today, both store-level and weekly-cadence:
///
///  - **PI (Pilferage Index)** — store-level shrinkage metric. The Trends
///    policy holds the entire store's incentive when PI ≥ 0.30%. Source
///    system TBD (asked RIL on the 28-Apr call). Stored as a percentage
///    figure (0.30 means 0.30%); `piHoldFlag` is computed at ingest time
///    so the engine doesn't re-derive the threshold per row.
///
///  - **GM (Gross Margin)** — per-store weekly GM% target and actual.
///    The policy says SM/DM only earn when sales target AND GM target are
///    both achieved. CSA is unaffected. `gmAchieved` is the canonical
///    truth value; the engine doesn't re-compare gmActual ≥ gmTarget so
///    that operations can manually override (e.g. "GM short by 0.1%, but
///    approved by ops") without changing the raw values.
///
/// Why a separate table (not folded into StorePeriodRollup): rollups are
/// engine output, this is engine input. Keeping inputs and outputs in
/// separate tables means a recompute can be re-driven without losing the
/// PI/GM data, and the ingest path doesn't have to know about CalculationRun.
///
/// Reversibility note: `(storeCode, periodStart, periodEnd)` is the natural
/// key. We use `periodStart` as the unique-by axis because F&L weeks are
/// fixed Sun–Sat — `periodEnd` is derivable but stored for query convenience.
model StoreWeeklyMetric {
  id             Int      @id @default(autoincrement())
  storeCode      String   @map("store_code") @db.VarChar(32)
  vertical       Vertical
  periodStart    DateTime @map("period_start") @db.Date
  periodEnd      DateTime @map("period_end") @db.Date
  /// Pilferage index as a percentage (0.30 = 0.30%). Optional — older
  /// imports may not have it; treated as "not on hold" when missing.
  pilferageIndex Decimal? @map("pilferage_index") @db.Decimal(8, 4)
  /// Pre-computed at ingest time using the active threshold (0.30% as of
  /// Apr 2026). Engine reads this directly so the threshold can shift
  /// without changing the engine.
  piHoldFlag     Boolean  @default(false) @map("pi_hold_flag")
  /// GM% target for the week (decimal fraction, e.g. 0.42 = 42%).
  gmTarget       Decimal? @map("gm_target") @db.Decimal(8, 4)
  /// GM% actual for the week (decimal fraction).
  gmActual       Decimal? @map("gm_actual") @db.Decimal(8, 4)
  /// Canonical GM-achieved truth value. Defaults to `gmActual >= gmTarget`
  /// at ingest time, but ops can override (write directly via admin path).
  /// Engine reads this — never re-compares the raw values.
  gmAchieved     Boolean  @default(false) @map("gm_achieved")
  /// Free-form note attached at ingest. Surface in admin drilldown so
  /// operators can see "Override: ops approved manual exception" or
  /// similar — the why behind a `gmAchieved=true` despite gmActual<gmTarget.
  note           String?  @db.Text
  source         String   @default("API") @db.VarChar(32)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@unique([storeCode, vertical, periodStart])
  @@index([vertical, periodStart])
  @@index([piHoldFlag, periodStart])
  @@map("store_weekly_metric")
}

model StoreDailyRollup {
  id               Int             @id @default(autoincrement())
  storeCode        String          @map("store_code") @db.VarChar(32)
  vertical         Vertical
  dayKey           DateTime        @map("day_key") @db.Date
  txnCount         Int             @default(0) @map("txn_count")
  grossAmount      Decimal         @default(0) @map("gross_amount") @db.Decimal(18, 2)
  netAmount        Decimal         @default(0) @map("net_amount") @db.Decimal(18, 2)
  unitsSold        Int             @default(0) @map("units_sold")
  lastRunId        String?         @map("last_run_id") @db.Uuid
  updatedAt        DateTime        @updatedAt @map("updated_at")
  lastRun          CalculationRun? @relation(fields: [lastRunId], references: [id], onDelete: SetNull)

  @@unique([storeCode, vertical, dayKey])
  @@index([vertical, dayKey])
  @@index([dayKey])
  @@map("store_daily_rollup")
}

/// Per-employee × plan × period snapshot. Primary read path for mobile hero
/// cards and drill-in employee detail. A single employee can have multiple
/// rows for the same period if they match multiple concurrent plans.
model EmployeePeriodRollup {
  id                Int             @id @default(autoincrement())
  employeeId        String          @map("employee_id") @db.VarChar(64)
  planId            Int             @map("plan_id")
  storeCode         String          @map("store_code") @db.VarChar(32)
  vertical          Vertical
  periodStart       DateTime        @map("period_start") @db.Date
  periodEnd         DateTime        @map("period_end") @db.Date
  earned            Decimal         @default(0) @db.Decimal(14, 2)
  eligible          Decimal         @default(0) @db.Decimal(14, 2)
  potential         Decimal         @default(0) @db.Decimal(14, 2)
  paid              Decimal         @default(0) @db.Decimal(14, 2)
  achievementPct    Decimal?        @map("achievement_pct") @db.Decimal(8, 2)
  multiplierApplied Decimal?        @map("multiplier_applied") @db.Decimal(8, 2)
  lastRunId         String          @map("last_run_id") @db.Uuid
  updatedAt         DateTime        @updatedAt @map("updated_at")
  plan              IncentivePlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  lastRun           CalculationRun  @relation(fields: [lastRunId], references: [id], onDelete: Restrict)

  @@unique([employeeId, planId, periodStart])
  @@index([planId, periodStart, periodEnd])
  @@index([storeCode, vertical, periodStart])
  @@index([employeeId, periodStart])
  @@map("employee_period_rollup")
}

/// Per-store × plan × period snapshot. Primary read path for the admin
/// dashboard store list and the mobile leaderboard. Rank-within-city is
/// pre-computed during the calculation run so leaderboard reads are a single
/// indexed query instead of a full-month groupBy over raw transactions.
model StorePeriodRollup {
  id              Int             @id @default(autoincrement())
  storeCode       String          @map("store_code") @db.VarChar(32)
  planId          Int             @map("plan_id")
  vertical        Vertical
  city            String
  state           String
  periodStart     DateTime        @map("period_start") @db.Date
  periodEnd       DateTime        @map("period_end") @db.Date
  targetValue     Decimal         @default(0) @map("target_value") @db.Decimal(18, 2)
  actualSales     Decimal         @default(0) @map("actual_sales") @db.Decimal(18, 2)
  achievementPct  Decimal         @default(0) @map("achievement_pct") @db.Decimal(8, 2)
  totalIncentive  Decimal         @default(0) @map("total_incentive") @db.Decimal(14, 2)
  employeeCount   Int             @default(0) @map("employee_count")
  earningCount    Int             @default(0) @map("earning_count")
  rankInCity      Int?            @map("rank_in_city")
  lastRunId       String          @map("last_run_id") @db.Uuid
  updatedAt       DateTime        @updatedAt @map("updated_at")
  plan            IncentivePlan   @relation(fields: [planId], references: [id], onDelete: Restrict)
  lastRun         CalculationRun  @relation(fields: [lastRunId], references: [id], onDelete: Restrict)

  @@unique([storeCode, planId, periodStart])
  @@index([vertical, city, periodStart, achievementPct(sort: Desc)])
  @@index([vertical, periodStart])
  @@index([planId, periodStart])
  @@map("store_period_rollup")
}

/// A single bulk sales ingest from an upstream system (Reliance POS firehose,
/// CSV upload, etc.). Dedup is by `idempotencyKey` — retried POSTs with the
/// same key replay the stored response instead of re-inserting. Row-level
/// dedup still relies on `SalesTransaction.transactionId` being the PK.
///
/// Inserts happen synchronously inside the POST; the recompute is deferred
/// to a `RecomputeJob`, so the ingest endpoint returns 202 in sub-second
/// even for 5K-row batches.
model IngestionBatch {
  id              Int              @id @default(autoincrement())
  idempotencyKey  String           @unique @map("idempotency_key") @db.VarChar(128)
  source          String           @default("API") @map("source") @db.VarChar(32)
  batchRef        String?          @map("batch_ref") @db.VarChar(128)
  submittedBy     String           @default("service") @map("submitted_by")
  status          IngestionStatus  @default(RECEIVED)
  rowsSubmitted   Int              @default(0) @map("rows_submitted")
  rowsAccepted    Int              @default(0) @map("rows_accepted")
  rowsRejected   Int              @default(0) @map("rows_rejected")
  /// Array of { row: number, error: string } for rejected rows. Capped at
  /// 100 entries so a malformed batch doesn't balloon the row.
  errorLog        Json?            @map("error_log")
  /// Min and max transactionDate in the batch — used by the recompute worker
  /// to size the date span without scanning the inserted rows again.
  minTxnDate      DateTime?        @map("min_txn_date") @db.Date
  maxTxnDate      DateTime?        @map("max_txn_date") @db.Date
  /// Distinct storeCodes touched by this batch. Drives recompute scope.
  storeCodes      String[]         @map("store_codes")
  createdAt       DateTime         @default(now()) @map("created_at")
  completedAt     DateTime?        @map("completed_at")
  recomputeJobs   RecomputeJob[]

  @@index([status, createdAt])
  @@index([createdAt])
  @@map("ingestion_batch")
}

/// Deferred recompute work. An ingest or manual trigger enqueues one row;
/// the cron worker (`/api/cron/run-jobs`) claims oldest-PENDING via
/// SELECT FOR UPDATE SKIP LOCKED, runs `recalculateByDateSpan`, marks
/// COMPLETED/FAILED. Decoupling lets ingestion return 202 immediately
/// instead of blocking the HTTP request on a 30–120s recompute.
model RecomputeJob {
  id                Int                @id @default(autoincrement())
  status            RecomputeJobStatus @default(PENDING)
  trigger           CalcRunTrigger
  storeCodes        String[]           @map("store_codes")
  periodStart       DateTime           @map("period_start") @db.Date
  periodEnd         DateTime           @map("period_end") @db.Date
  ingestionBatchId  Int?               @map("ingestion_batch_id")
  enqueuedBy        String             @default("system") @map("enqueued_by")
  claimedAt         DateTime?          @map("claimed_at")
  completedAt       DateTime?          @map("completed_at")
  attempts          Int                @default(0)
  errorMessage      String?            @map("error_message") @db.Text
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  ingestionBatch    IngestionBatch?    @relation(fields: [ingestionBatchId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([ingestionBatchId])
  @@map("recompute_job")
}

model AuditLog {
  id          Int             @id @default(autoincrement())
  entityType  AuditEntityType @map("entity_type")
  entityId    Int             @map("entity_id")
  action      AuditAction
  oldValue    Json?           @map("old_value")
  newValue    Json?           @map("new_value")
  performedBy String          @default("system") @map("performed_by")
  performedAt DateTime        @default(now()) @map("performed_at")

  @@index([entityType, entityId, performedAt])
  @@map("audit_log")
}

/// Phase 6.1 (Grocery HR Sales pilot) — per-store-month external metrics.
/// Mirror of `StoreWeeklyMetric` but on a monthly cadence (the Grocery
/// pilot runs monthly, not weekly). Carries:
///
///   1. **Sales achievement** — denormalized `salesBudgetRsLacs`,
///      `salesActualRsLacs`, and `salesAchievementPct`. The values are
///      ALSO computable from raw sales_transaction rows but RIL ships
///      them in the working file directly, and the engine reads them as
///      authoritative so a re-ingest of corrections (e.g., "March actual
///      was off, here's the corrected number") drives a recompute without
///      having to retroactively edit POS data. `salesBucket` is the band
///      label as ingested ("100% - 110%", ">=120%", etc.) for audit.
///
///   2. **Quality gates** — Mystery Shopper rating × POP Compliance
///      rating drive the canonical `salesStatus` truth value. Computed at
///      ingest (both GREEN → ALL_STAFF_QUALIFIED; any AMBER →
///      ONLY_ASSOCIATES_QUALIFIED; any RED → NONE_QUALIFIED) but stored so
///      ops can override post-ingest without re-deriving.
///
/// Why a separate table from StoreWeeklyMetric: different cadence, different
/// gate semantics (PI/GM are blocking-or-not flags, here we have a
/// three-state status), and different engine path. Folding them into one
/// generic `StorePeriodMetric` would over-abstract — better to keep each
/// vertical's input shape explicit.
model StoreMonthlyMetric {
  id                   Int               @id @default(autoincrement())
  storeCode            String            @map("store_code") @db.VarChar(32)
  vertical             Vertical
  periodStart          DateTime          @map("period_start") @db.Date
  periodEnd            DateTime          @map("period_end") @db.Date

  /// Sales budget for the month, in Rs Lacs (RIL's unit of choice).
  /// The engine converts to Rs internally for math.
  salesBudgetRsLacs    Decimal?          @map("sales_budget_rs_lacs") @db.Decimal(12, 4)
  /// Sales actual for the month, in Rs Lacs.
  salesActualRsLacs    Decimal?          @map("sales_actual_rs_lacs") @db.Decimal(12, 4)
  /// Sales actual ÷ budget, as decimal fraction (1.10 = 110%).
  salesAchievementPct  Decimal?          @map("sales_achievement_pct") @db.Decimal(8, 4)
  /// Band label as ingested (e.g., ">=120%", "100% - 110%"). Stored for
  /// audit; the engine derives the active band from `salesAchievementPct`
  /// against the `GrocerySalesSlab.bandMin/Max` ranges, not from this label.
  salesBucket          String?           @map("sales_bucket") @db.VarChar(32)

  mysteryShopperRating StoreRating?      @map("mystery_shopper_rating")
  popComplianceRating  StoreRating?      @map("pop_compliance_rating")
  /// Canonical quality-gate truth value. Engine reads this; ops can
  /// override for explicit exceptions (the override fields on the ingest
  /// endpoint write directly here, bypassing rating-based derivation).
  salesStatus          StoreSalesStatus? @map("sales_status")

  note                 String?           @db.Text
  source               String            @default("API") @db.VarChar(32)
  createdAt            DateTime          @default(now()) @map("created_at")
  updatedAt            DateTime          @updatedAt @map("updated_at")

  @@unique([storeCode, vertical, periodStart])
  @@index([vertical, periodStart])
  @@index([salesStatus, periodStart])
  @@map("store_monthly_metric")
}

/// Phase 6.1 — per-employee-month inputs for Grocery HR Sales calc.
/// Three groups of fields:
///
///   1. **Attendance arithmetic** — `attendance` is the count of days the
///      employee was on rolls in the month (often = days_in_month for
///      active employees). `awlDays` is "Authorized With Leave" — approved
///      leave that reduces working days. `workingDays` is the final number
///      used for the pro-rata divisor. RIL ships all three; we don't
///      re-derive from per-day Attendance rows because the .xlsb is the
///      source of truth for the pilot (their HR system computes these
///      with rules we don't see).
///
///   2. **Reconciliation hooks** — `rilIncentiveSlab` and `rilFinalPay`
///      are RIL's pre-computed values from the working file. We store
///      them so the reconciliation script can do per-row diffs (engine vs
///      RIL) without joining back to the raw file.
///
///   3. **Per-employee snapshot fields** are NOT here — Position Name,
///      EEGrp, etc. live on EmployeeMaster (long-lived) or get derived
///      from EmployeeRole (the engine's discriminator).
///
/// Why a separate table from Attendance: different cadence (monthly vs
/// per-day), different semantics (RIL-provided aggregates vs raw status
/// rows), and the per-day Attendance rows aren't always available for
/// Grocery (RIL may ship only the monthly aggregate for the pilot).
model EmployeeMonthlyInput {
  id              Int            @id @default(autoincrement())
  employeeId      String         @map("employee_id") @db.VarChar(64)
  periodStart     DateTime       @map("period_start") @db.Date
  periodEnd       DateTime       @map("period_end") @db.Date

  /// Total days the employee was on rolls in the month.
  attendance      Int
  /// Approved-leave days (subtracted from working days).
  awlDays         Int            @default(0) @map("awl_days")
  /// Effective working days = attendance − awlDays − other absences.
  /// RIL ships this directly; engine uses it for pro-rata math.
  workingDays     Int            @map("working_days")

  /// RIL's pre-computed slab amount from the working file. Engine doesn't
  /// read this — it's purely for the reconciliation script.
  rilIncentiveSlab Decimal?      @map("ril_incentive_slab") @db.Decimal(12, 2)
  /// RIL's pre-computed final pay from the working file (slab × wd / att).
  /// Reconciliation ground-truth for engine output diff.
  rilFinalPay      Decimal?      @map("ril_final_pay") @db.Decimal(12, 2)

  source          String         @default("API") @db.VarChar(32)
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  employee        EmployeeMaster @relation(fields: [employeeId], references: [employeeId], onDelete: Restrict)

  @@unique([employeeId, periodStart])
  @@index([periodStart])
  @@map("employee_monthly_input")
}

/// Phase 6.1 — Grocery HR Sales slab matrix.
///
/// One row per (planId, formatTier, roleBucket, achievement-band). The
/// engine looks up the row matching the store's tier, the employee's
/// role-bucket, and where the store's `salesAchievementPct` falls in the
/// `[bandMinPct, bandMaxPct)` range.
///
/// Bands are stored as decimal fractions, half-open intervals:
///   - `bandMinPct = 0.85`, `bandMaxPct = 0.95` → 85% ≤ ach < 95%
///   - `bandMaxPct = NULL` → ach ≥ bandMinPct (the ">=120%" top band)
///   - The "<85%" / "<95%" zero-payout band can be encoded explicitly
///     (bandMinPct=0, bandMaxPct=0.85, amountRs=0) or omitted (engine
///     defaults to 0 when no band matches).
///
/// Reversibility note: the matrix shape (band count, role-bucket count)
/// is encoded as data, not code — so a v2 policy with different bands or
/// new role buckets can be re-seeded without touching the engine. The
/// engine just walks the rows for the active plan.
model GrocerySalesSlab {
  id              Int                @id @default(autoincrement())
  planId          Int                @map("plan_id")
  formatTier      FormatTier         @map("format_tier")
  roleBucket      GroceryRoleBucket  @map("role_bucket")
  /// Min achievement (inclusive), as decimal fraction.
  bandMinPct      Decimal            @map("band_min_pct") @db.Decimal(6, 4)
  /// Max achievement (exclusive). NULL = +infinity (top band).
  bandMaxPct      Decimal?           @map("band_max_pct") @db.Decimal(6, 4)
  /// Slab payout amount in Rs (the .xlsb stores 250, 325, 500, 650, 850,
  /// 1000, 1100, 1400, 1800, 2300, 2400, 3000 etc.).
  amountRs        Decimal            @map("amount_rs") @db.Decimal(12, 2)
  effectiveFrom   DateTime?          @map("effective_from") @db.Date
  effectiveTo     DateTime?          @map("effective_to") @db.Date
  plan            IncentivePlan      @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@unique([planId, formatTier, roleBucket, bandMinPct])
  @@index([planId, formatTier, roleBucket])
  @@map("grocery_sales_slab")
}

/// Phase 6.1 — Grocery Category PIP (Per-Piece Incentive) article catalog.
///
/// One row per article in a category-PIP plan (e.g., the 17 Dairy Day SKUs
/// in the Mar'26 Ice Cream plan). The engine matches sales transactions
/// against `articleCode` and pays `rateRs × qtySold`, gated by the min
/// criteria threshold (default 80% of `targetQty`).
///
/// Below threshold = zero payout. Engine emits `BELOW_MIN_CRITERIA` reason.
///
/// Why article-level (not department-level): the policy varies rate per
/// SKU (₹5 for 700ml CBD, ₹2 for 500ml TUB) and target per SKU. A single
/// department-level rate would lose this granularity. The match is on
/// `SalesTransaction.articleCode` so no new ingest is needed — the
/// existing /api/ingest/sales pipeline already carries article codes.
model CategoryPipArticle {
  id              Int            @id @default(autoincrement())
  planId          Int            @map("plan_id")
  /// Article identifier (RIL article number). Matched against
  /// `SalesTransaction.articleCode` at calc time.
  articleCode     String         @map("article_code")
  articleDesc     String?        @map("article_desc")
  brand           String?
  /// Per-piece incentive amount in Rs. The .xlsb has ₹5 and ₹2 tiers.
  rateRs          Decimal        @map("rate_rs") @db.Decimal(8, 2)
  /// Target quantity (pieces) for the period. Most rows in the Mar'26
  /// file are 125; outliers exist (25, 75, 100, 175, 250, 300, 1175).
  targetQty       Int            @map("target_qty")
  /// Min-criteria threshold as a fraction of targetQty. Below this, no
  /// payout. RIL default is 0.80 (80%) — encoded as default so missing
  /// values from ingest still gate sensibly.
  minCriteriaPct  Decimal        @default(0.80) @map("min_criteria_pct") @db.Decimal(4, 2)
  effectiveFrom   DateTime?      @map("effective_from") @db.Date
  effectiveTo     DateTime?      @map("effective_to") @db.Date
  plan            IncentivePlan  @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@unique([planId, articleCode])
  @@index([planId])
  @@map("category_pip_article")
}
