# Database (required)
DATABASE_URL="postgresql://user:password@host:5432/incentive_os?schema=public"

# Auth (required in production, optional in dev)
JWT_SECRET="your-secure-random-string-at-least-32-chars"

# CORS — comma-separated origins allowed to call the API
# Use * for development, restrict in production
ALLOWED_ORIGIN="*"

# Seed endpoint — set to "true" to enable POST /api/seed
ENABLE_SEED="false"
